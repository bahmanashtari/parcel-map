# Django Environment
# Allowed values: development, production
DJANGO_ENV=

# Enable Django debug mode (should be False in production)
DEBUG=

# Secret key for sessions and tokens (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=

# Database Configuration
# PostgreSQL username
POSTGRES_USER=
# PostgreSQL password
POSTGRES_PASSWORD=
# Database name
POSTGRES_DB=
# Database host
DB_HOST=
# Database port
DB_PORT=
# Django database backend engine
DB_ENGINE=
# Database connection max age in seconds
DB_CONN_MAX_AGE=

# CORS Configuration
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=

# API Configuration
# Number of items per page for API pagination
API_PAGE_SIZE=

# Logging
# Log level for all loggers (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=
# Log level for Django logger
DJANGO_LOG_LEVEL=
# Log level for database query logger
DB_LOG_LEVEL=

# Email Configuration (for production)
# SMTP server hostname
EMAIL_HOST=
# SMTP server port
EMAIL_PORT=
# Use TLS for email (True/False)
EMAIL_USE_TLS=
# Email account username
EMAIL_HOST_USER=
# Email account password
EMAIL_HOST_PASSWORD=

# SSL/Security (production)
# Redirect HTTP to HTTPS (True/False)
SECURE_SSL_REDIRECT=
# HSTS max age in seconds
SECURE_HSTS_SECONDS=

# Cache Configuration
# Cache backend: locmem or redis
CACHE_BACKEND=
# Redis connection URL (required if CACHE_BACKEND=redis)
REDIS_URL=

# Static/Media Files
# URL path for static files
STATIC_URL=
# URL path for media files (user uploads)
MEDIA_URL=

# GIS/PostGIS Libraries (optional, if needed for custom locations)
# Path to GDAL library (if not in system PATH)
GDAL_LIBRARY_PATH=
# Path to GEOS library (if not in system PATH)
GEOS_LIBRARY_PATH=

# Sentry Error Tracking (optional)
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
# Sample rate for tracing (0.0-1.0)
SENTRY_TRACE_SAMPLE_RATE=
